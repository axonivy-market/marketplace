pipeline {
    agent any // Assumes a Jenkins agent with Git, Docker, and necessary tools installed

    parameters {
        string(name: 'RELEASE_VERSION', defaultValue: 'latest', description: 'Release version')
        string(name: 'BUILD_ENV', defaultValue: 'production', description: 'Build environment')
    }

    environment {
        UI_IMAGE_NAME = 'marketplace-ui'
        SERVICE_IMAGE_NAME = 'marketplace-service'
        GITHUB_TOKEN = credentials('github-token') // Jenkins credential ID for GitHub token
        GITHUB_REGISTRY = 'ghcr.io'
        GITHUB_OWNER = "${env.JOB_NAME.split('/')[0]}" // Assumes job name includes repo owner
    }

    stages {
        stage('Checkout Repository') {
          steps {
            git branch: 'develop', url: 'https://github.com/axonivy-market/marketplace.git'
            sh '''
              mvn clean install --file ./marketplace-service/pom.xml
            '''
          }
        }

        stage('Update Version and Tag Source') {
            when {
                expression { params.RELEASE_VERSION != '' }
            }
            steps {
                script {
                    sh """
                        xmlstarlet ed -L -u '//project/version' -v '${params.RELEASE_VERSION}' marketplace-service/pom.xml
                    """

                    sh """
                        sed -i 's/\\"version\\": \\"[^\\"]*\\"/\\"version\\": \\"${params.RELEASE_VERSION}\\"/' marketplace-ui/package.json
                    """

                    // Configure Git user for commits
                    sh """
                        git config user.email 'jenkins@ci.com'
                        git config user.name 'Jenkins CI'
                    """

                    // Delete existing tag if it exists
                    sh """
                        git push origin :refs/tags/${params.RELEASE_VERSION} || true
                        git tag -d ${params.RELEASE_VERSION} || true
                    """

                    // Commit changes and create new tag
                    sh """
                        git commit -a -m 'Update version to ${params.RELEASE_VERSION}'
                        git tag ${params.RELEASE_VERSION}
                        git push origin ${params.RELEASE_VERSION}
                    """
                }
            }
        }

        stage('Build Docker Images') {
            steps {
                script {
                    // Placeholder for Docker build (equivalent to docker-build.yml)
                    // Assuming the build creates images named UI_IMAGE_NAME and SERVICE_IMAGE_NAME
                    sh """
                        docker build -t ${env.UI_IMAGE_NAME} ./marketplace-ui
                        docker build -t ${env.SERVICE_IMAGE_NAME} ./marketplace-service
                    """
                }
            }
        }

        stage('Wait for Containers') {
            steps {
                dir('marketplace-build') {
                    script {
                        // Wait for Docker Compose containers to be up (up to 300 seconds)
                        sh """
                            timeout=300
                            start_time=\$(date +%s)
                            while [ \$((\$(date +%s) - start_time)) -lt \$timeout ]; do
                                if docker compose ps | grep -q 'Up'; then
                                    echo 'Containers are up and running.'
                                    exit 0
                                fi
                                echo 'Waiting for containers to start...'
                                sleep 5
                            done
                            echo 'Containers did not start within the timeout period.'
                            exit 1
                        """
                    }
                }
            }
        }

        stage('Log in to GitHub Container Registry') {
            steps {
                script {
                    // Log in to GitHub Container Registry using GITHUB_TOKEN
                    sh """
                        echo ${env.GITHUB_TOKEN} | docker login ${env.GITHUB_REGISTRY} -u ${env.GITHUB_OWNER} --password-stdin
                    """
                }
            }
        }

        stage('Refine Release Version') {
            steps {
                script {
                    // Refine release version (e.g., map 'main' to 'latest')
                    def version = params.RELEASE_VERSION
                    if (version == 'main') {
                        version = 'latest'
                    }
                    env.VERSION = version
                }
            }
        }

        stage('Release Marketplace UI Image') {
            steps {
                script {
                    // Tag and push UI image to GitHub Packages
                    sh """
                        UI_IMAGE_ID=${env.GITHUB_REGISTRY}/${env.GITHUB_OWNER}/${env.UI_IMAGE_NAME}
                        docker tag ${env.UI_IMAGE_NAME} \${UI_IMAGE_ID}:${env.VERSION}
                        docker push \${UI_IMAGE_ID}:${env.VERSION}
                    """
                }
            }
        }

        stage('Release Marketplace Service Image') {
            steps {
                script {
                    // Tag and push Service image to GitHub Packages
                    sh """
                        SERVICE_IMAGE_ID=${env.GITHUB_REGISTRY}/${env.GITHUB_OWNER}/${env.SERVICE_IMAGE_NAME}
                        docker tag ${env.SERVICE_IMAGE_NAME} \${SERVICE_IMAGE_ID}:${env.VERSION}
                        docker push \${SERVICE_IMAGE_ID}:${env.VERSION}
                    """
                }
            }
        }
    }

    post {
        always {
            // Clean up Docker images to save space
            sh """
                docker rmi ${env.UI_IMAGE_NAME} || true
                docker rmi ${env.SERVICE_IMAGE_NAME} || true
            """
        }
    }
}