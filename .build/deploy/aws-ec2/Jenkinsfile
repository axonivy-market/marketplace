@NonCPS
def resolveNodesToDeploy(String deploymentTarget, Map deploymentConfig) {
    return deploymentConfig[deploymentTarget]
}

@NonCPS
def parseJsonData(String jsonContent) {
    return new groovy.json.JsonSlurperClassic().parseText(jsonContent)
}

def deploymentConfig = [:]
def nodesToDeploy = []

pipeline {
    agent any

    options {
        ansiColor('xterm')
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
    }

    environment {
        MARKETPLACE_GIT_URL = credentials('MARKETPLACE_GIT_URL')
    }

    parameters {
        choice(
            name: 'DEPLOYMENT_TARGET',
            choices: [
                'PREVIEW node',
                'PROD_1 node',
                'PROD_2 node',
                'All PROD nodes'
            ],
            description: 'Select which node(s) to deploy to'
        )
        string(
            name: 'RELEASE_VERSION',
            description: 'Release version (e.g., 1.2.0)'
        )
    }

    stages {

        stage('Checkout Source') {
            steps {
                script {
                    sh 'rm -rf target-source'
                    dir('target-source') {
                        git branch: 'develop', url: env.MARKETPLACE_GIT_URL
                    }
                }
            }
        }

        stage('Confirm Production Deployment') {
            when {
                expression { params.DEPLOYMENT_TARGET != 'PREVIEW node' }
            }
            steps {
                script {
                    def requester = currentBuild.getBuildCauses('hudson.model.Cause$UserIdCause')?.first()?.userId ?: 'SYSTEM'
                    def approverUsernames = []
                    configFileProvider([configFile(fileId: 'deployment-approvers', variable: 'DEPLOYMENT_APPROVERS_FILE')]) {
                        def approversContent = readFile(file: env.DEPLOYMENT_APPROVERS_FILE)
                        def approversConfig = parseJsonData(approversContent)
                        approverUsernames = approversConfig?.approvers ?: []
                    }

                    if (!approverUsernames) {
                        error('No approvers configured. Please set at least one username in managed file deployment-approvers under key approvers.')
                    }

                    def submitterList = approverUsernames.join(',')
                    def approver = input(
                        message: "Deploy version ${params.RELEASE_VERSION} to ${params.DEPLOYMENT_TARGET}?",
                        submitter: submitterList,
                        submitterParameter: 'APPROVED_BY',
                        ok: 'Approve deployment'
                    )

                    if (approver == requester) {
                        error("4-eyes policy violation: requester '${requester}' cannot self-approve. Approval must be done by another configured approver.")
                    }

                    echo "4-eyes approval passed: requested by '${requester}', approved by '${approver}' (allowed approvers: ${submitterList})."
                }
            }
        }

        stage('Load Configuration') {
            steps {
                script {
                    configFileProvider([configFile(fileId: 'deployment-target', variable: 'DEPLOYMENT_TARGETS_FILE')]) {
                        def jsonContent = readFile(file: env.DEPLOYMENT_TARGETS_FILE)
                        deploymentConfig = parseJsonData(jsonContent)
                        nodesToDeploy = resolveNodesToDeploy(params.DEPLOYMENT_TARGET, deploymentConfig) ?: []
                        echo "Resolved ${nodesToDeploy?.size() ?: 0} node(s) for ${params.DEPLOYMENT_TARGET}"
                    }
                }
            }
        }

        stage('Merge Configuration') {
            steps {
                script {
                    for (node in nodesToDeploy) {
                        echo "Merging config for node: ${node.name} (${node.ip})"

                        withCredentials([
                            string(credentialsId: node.credId, variable: 'EC2_NODE'),
                            sshUserPrivateKey(credentialsId: 'aws-ec2-ssh-key', keyFileVariable: 'SSH_PRIVATE_KEY_FILE', usernameVariable: 'SSH_REMOTE_USER'),
                            file(credentialsId: node.envCredId, variable: 'ENV_SECRET_FILE')
                        ]) {
                            sh """
                                set +x
                                export SSH_PRIVATE_KEY_FILE="\${SSH_PRIVATE_KEY_FILE}"
                                export SSH_REMOTE_USER="\${SSH_REMOTE_USER}"
                                export WORKSPACE_ROOT="${env.WORKSPACE}"
                                bash ./target-source/.build/deploy/aws-ec2/scripts/merge-config.sh \
                                    "\${EC2_NODE}" \
                                    "${params.RELEASE_VERSION}" \
                                    "${node.nginxPort}" \
                                    "\${ENV_SECRET_FILE}"
                            """
                        }
                    }
                }
            }
        }

        stage('Deploy and Promote Release') {
            steps {
                script {
                    for (node in nodesToDeploy) {
                        echo "Deploying and promoting release for node: ${node.name} (${node.ip})"

                        withCredentials([
                            string(credentialsId: node.credId, variable: 'EC2_NODE'),
                            sshUserPrivateKey(credentialsId: 'aws-ec2-ssh-key', keyFileVariable: 'SSH_PRIVATE_KEY_FILE', usernameVariable: 'SSH_REMOTE_USER'),
                            usernamePassword(credentialsId: 'ghcr-io-token', usernameVariable: 'GHCR_USERNAME', passwordVariable: 'GHCR_TOKEN')
                        ]) {
                            sh """
                                set +x
                                export SSH_PRIVATE_KEY_FILE="\${SSH_PRIVATE_KEY_FILE}"
                                export SSH_REMOTE_USER="\${SSH_REMOTE_USER}"
                                export GHCR_USERNAME="\${GHCR_USERNAME}"
                                export GHCR_TOKEN="\${GHCR_TOKEN}"
                                export WORKSPACE_ROOT="${env.WORKSPACE}"
                                bash ./target-source/.build/deploy/aws-ec2/scripts/deploy-and-promote.sh \
                                    "\${EC2_NODE}" \
                                    "${params.RELEASE_VERSION}" \
                                    "${node.healthCheckEndpoints}"
                            """
                        }
                    }
                }
            }
        }
    }
}
