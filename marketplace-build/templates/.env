NGINX_CONFIG_PATH=../config/nginx/nginx.conf
NGINX_PORT=80
BUILD_ENV=staging
BUILD_VERSION=1.0.0-SNAPSHOT
RELEASE_VERSION=1.0.0-SNAPSHOT
MARKET_API_URL=/app
MARKET_API_INTERNAL_URL=
MARKET_DAY_IN_MILLISECONDS=
MARKET_MATOMO_TRACKER_URL=
MARKET_ALLOWED_HOSTS=
MARKET_GITHUB_API_URL=https://api.github.com
MARKET_GITHUB_OAUTH_CALLBACK=/auth/github/callback
MARKET_JWT_SECRET_KEY=
MARKET_CORS_ALLOWED_ORIGIN=*
MARKET_CORS_ALLOWED_MAPPINGS=/**
MARKET_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
MARKET_LOG_PATH=logs/loggable
LOGGING_FILE_PATH=logs/logging
STABLE_LOG_PATH=logs/stable
APP_LOG_PATH=logs/app
NGINX_LOG_PATH=logs/nginx
NGINX_CACHE_PATH=cache
LOGGING_SQL_LEVEL=INFO
POSTGRES_HOST_URL=
POSTGRES_USERNAME=
POSTGRES_PASSWORD=
HIKARI_MAX_POOL_SIZE=
HIKARI_MIN_IDLE=
SHOW_SQL=true
MARKET_ENVIRONMENT=production
SESSION_COOKIE_SECURE=
MARKET_ENCRYPTION_SECRET_KEY=
MARKET_NODE_NUMBER=